sequenceDiagram
    autonumber
    actor Player
    participant Cursor as Cursor/UI
    participant GC as GameController
    participant Mouse as Mouse
    participant Grid as Grid
    participant Score as ScoreManager

    %% Player provides direction through UI
    Player->>Cursor: inputDirection(dir)

    %% UI hands off to GameController
    Cursor->>GC: requestMove(dir)

    %% GC delegates the move to the Mouse (providing grid context)
    GC->>Mouse: move(dir, grid)

    %% Mouse validates via Grid
    Mouse->>Grid: inBounds(nextX, nextY)?
    Grid-->>Mouse: true/false

    alt Out of bounds
        Mouse-->>GC: moveResult(false, "OOB")
        GC-->>Cursor: moveResult(false, "OOB")
    else In bounds
        Mouse->>Grid: isOccupied(nextX, nextY)?
        Grid-->>Mouse: true/false

        alt Blocked
            Mouse-->>GC: moveResult(false, "Blocked")
            GC-->>Cursor: moveResult(false, "Blocked")
        else Free
            Mouse->>Mouse: updatePosition(nextX, nextY)
            Mouse-->>GC: moveResult(true)

            %% GC updates scoring and notifies UI
            GC->>Score: recordMove()
            Score-->>GC: return
            GC-->>Cursor: moveResult(true)
        end
    end