classDiagram
    direction LR

    class GameController {
      +Grid grid
      +Mouse mouse
      +Cursor cursor
      +ScoreManager scoreManager
      +initializeGame() void
      +requestMove(dir:Direction) bool
      +processTurn() void
      +checkEndConditions() void
    }

    class Grid {
      +int width
      +int height
      +Cell[][] cells
      +List~Wall~ walls
      +Point mouseStart
      +inBounds(x:int, y:int) bool
      +isOccupied(x:int, y:int) bool
      +placeWall(w:Wall) bool
      +removeWall(w:Wall) bool
      +getNeighbors(x:int, y:int) List~Point~
    }

    class Mouse {
      +Point position
      +MouseState state
      +int movesTaken
      +int powerTicksLeft
      +move(dir:Direction, grid:Grid) bool
      +enterPowerMode(ticks:int) void
      +tick(grid:Grid) void
    }

    class Cursor {
      +Point hover
      +bool placingMode
      +selectCell(x:int, y:int) void
      +placeWall(grid:Grid) bool
      +removeWall(grid:Grid) bool
      +rotatePlacement() void
    }

    class Wall {
      +Point position
      +Orientation orientation
      +bool destructible
      +int durability
      +takeHit() void
      +isBroken() bool
    }

    class ScoreManager {
      +int score
      +int moves
      +int timeElapsed
      +int wallsPlaced
      +startTimer() void
      +stopTimer() void
      +recordMove() void
      +recordWallPlaced() void
      +applyMouseEscapeBonus() void
      +applyMouseTrappedPenalty() void
    }

    %% Utility classes
    class Cell {
      +bool passable
    }

    class Point {
      +int x
      +int y
    }

    class Direction {
      <<enumeration>>
      UP
      DOWN
      LEFT
      RIGHT
    }

    class Orientation {
      <<enumeration>>
      HORIZONTAL
      VERTICAL
    }

    class MouseState {
      <<enumeration>>
      IDLE
      MOVING
      POWERED
      TRAPPED
      ESCAPED
    }

    %% Relationships

    %% GameController owns the subsystems
    GameController --> Grid : manages
    GameController --> Mouse : controls
    GameController --> Cursor : uses
    GameController --> ScoreManager : updates

    %% System relationships
    Grid "1" o-- "many" Cell : composition
    Grid "1" o-- "0..*" Wall : composition
    Mouse "1" --> "1" Grid : queries for movement
    Cursor "1" --> "1" Grid : places walls
    Cursor "1" --> "0..*" Wall : creates/removes walls
    ScoreManager "1" ..> Mouse : observes events
    ScoreManager "1" ..> Grid : optional end checks
    ScoreManager "1" ..> Cursor : wall/move stats
    Wall "1" --> "1" Grid : located on grid