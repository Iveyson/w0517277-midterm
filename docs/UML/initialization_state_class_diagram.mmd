classDiagram
    direction LR

    class Grid {
      +int width
      +int height
      +Cell[][] cells
      +List~Wall~ walls
      +Point mouseStart
      +bool inBounds(x:int, y:int) bool
      +isOccupied(x:int, y:int) bool
      +placeWall(w:Wall) bool
      +removeWall(w:Wall) bool
      +getNeighbors(x:int, y:int) List~Point~
    }

    class Mouse {
      +Point position
      +MouseState state
      +int movesTaken
      +int powerTicksLeft
      +move(dir:Direction, grid:Grid) bool
      +enterPowerMode(ticks:int) void
      +tick(grid:Grid) void
    }

    class Cursor {
      +Point hover
      +bool placingMode
      +selectCell(x:int, y:int) void
      +placeWall(grid:Grid) bool
      +removeWall(grid:Grid) bool
      +rotatePlacement() void
    }

    class Wall {
      +Point position
      +Orientation orientation
      +bool destructible
      +int durability
      +takeHit() void
      +isBroken() bool
    }

    class ScoreManager {
      +int score
      +int moves
      +int timeElapsed
      +int wallsPlaced
      +startTimer() void
      +stopTimer() void
      +recordMove() void
      +recordWallPlaced() void
      +applyMouseEscapeBonus() void
      +applyMouseTrappedPenalty() void
    }

    %% Value types / enums (as helper types)
    class Point {
      +int x
      +int y
    }

    class Cell {
      +bool passable
    }

    class Direction {
      <<enumeration>>
      UP
      DOWN
      LEFT
      RIGHT
    }

    class Orientation {
      <<enumeration>>
      HORIZONTAL
      VERTICAL
    }

    class MouseState {
      <<enumeration>>
      IDLE
      MOVING
      POWERED
      TRAPPED
      ESCAPED
    }

    %% Relationships
    Grid "1" o-- "many" Cell : composition
    Grid "1" o-- "0..*" Wall : composition
    Mouse "1" --> "1" Grid : queries pathing
    Cursor "1" --> "1" Grid : modifies placement
    Cursor "1" --> "0..*" Wall : creates/removes
    ScoreManager "1" ..> Mouse : observes events
    ScoreManager "1" ..> Cursor : observes walls/moves
    ScoreManager "1" ..> Grid : optional for end/escape checks
    Wall "1" --> "1" Grid : positioned on